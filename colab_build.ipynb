#!/bin/bash
# 阿里云 Cloud Shell 构建脚本
# 用于将 Kivy 应用构建为 Android APK

set -e

echo "=========================================="
echo "  血糖监测应用 - Cloud Shell 构建脚本"
echo "=========================================="

# 1. 安装依赖
echo "[1/6] 安装系统依赖..."
sudo apt-get update
sudo apt-get install -y \
    python3-pip \
    python3-venv \
    git \
    zip \
    unzip \
    openjdk-17-jdk \
    autoconf \
    libtool \
    pkg-config \
    zlib1g-dev \
    libncurses5-dev \
    libncursesw5-dev \
    libtinfo5 \
    cmake \
    libffi-dev \
    libssl-dev \
    automake

# 2. 安装 buildozer 和 cython
echo "[2/6] 安装 buildozer 和依赖..."
pip3 install --user buildozer cython

# 3. 配置环境变量
echo "[3/6] 配置环境变量..."
echo 'export PATH=$PATH:~/.local/bin' >> ~/.bashrc
source ~/.bashrc

# 4. 下载 Android SDK/NDK（如果尚未下载）
echo "[4/6] 检查 Android SDK/NDK..."
if [ ! -d "~/.buildozer/android/platform/android-sdk" ]; then
    echo "首次构建，需要下载 Android SDK/NDK（约 1GB+，请耐心等待）..."
fi

# 5. 开始构建
echo "[5/6] 开始构建 APK..."
echo "注意：首次构建可能需要 30-60 分钟，请耐心等待..."
~/.local/bin/buildozer android debug

# 6. 检查构建结果
echo "[6/6] 检查构建结果..."
if [ -f "bin/healthcare-1.0.0-arm64-v8a_armeabi-v7a-debug.apk" ]; then
    echo "=========================================="
    echo "  构建成功！"
    echo "=========================================="
    echo "APK 文件位置: bin/healthcare-1.0.0-arm64-v8a_armeabi-v7a-debug.apk"
    echo "文件大小: $(du -h bin/healthcare-1.0.0-arm64-v8a_armeabi-v7a-debug.apk | cut -f1)"
    echo ""
    echo "下载方式:"
    echo "1. 在 Cloud Shell 中点击文件浏览器"
    echo "2. 进入 healthcare_android/bin/ 目录"
    echo "3. 右键点击 APK 文件下载"
else
    echo "构建可能失败，请检查日志"
    exit 1
fi
